{
	"name": "fibx",
	"version": "0.1.4",
	"description": "A powerful CLI for DeFi operations on Base, Citrea, HyperEVM, and Monad, powered by Fibrous.",
	"type": "module",
	"bin": {
		"fibx": "dist/index.js"
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "tsc",
		"dev": "node --env-file=.env --import tsx/esm src/index.ts",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@privy-io/node": "^0.8.0",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"env-paths": "^3.0.0",
		"ora": "^9.3.0",
		"viem": "^2.45.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/node": "^25.2.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.55.0"
	},
	"engines": {
		"node": ">=18"
	},
	"keywords": [
		"wallet",
		"fibrous",
		"defi",
		"base",
		"citrea",
		"hyperevm",
		"monad",
		"cli",
		"swap",
		"agent",
		"ai",
		"mcp",
		"skills"
	],
	"license": "MIT"
}
