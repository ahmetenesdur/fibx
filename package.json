{
	"name": "fibx",
	"version": "0.7.0",
	"description": "Zero-dependency CLI for DeFi operations on Base, Citrea, HyperEVM, and Monad — powered by Fibrous aggregation, with built-in MCP server for AI agents.",
	"author": "Ahmet Enes Dur",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmetenesdur/fibx.git"
	},
	"bugs": {
		"url": "https://github.com/ahmetenesdur/fibx/issues"
	},
	"homepage": "https://github.com/ahmetenesdur/fibx#readme",
	"type": "module",
	"bin": {
		"fibx": "dist/index.js"
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "tsup",
		"dev": "node --env-file=.env --import tsx/esm src/index.ts",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@types/inquirer": "^9.0.9",
		"@types/node": "^25.5.0",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"env-paths": "^3.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"inquirer": "^13.3.2",
		"ora": "^9.3.0",
		"prettier": "^3.8.1",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"viem": "^2.47.5",
		"zod": "^4.3.6"
	},
	"engines": {
		"node": ">=18"
	},
	"keywords": [
		"wallet",
		"fibrous",
		"defi",
		"base",
		"citrea",
		"hyperevm",
		"monad",
		"cli",
		"swap",
		"agent",
		"ai",
		"mcp",
		"skills"
	],
	"license": "MIT"
}
